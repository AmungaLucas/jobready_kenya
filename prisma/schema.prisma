  MPESA
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
  EXPIRED
  REFUNDED
}

enum PaymentItemType {
  SUBSCRIPTION
  PRIORITY_APPLICATION
  CV_REVIEW
  FEATURED_JOB
}

enum SubscriptionTier {
  FREE
  BASIC_PREMIUM
  PRO_PREMIUM
